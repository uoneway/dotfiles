{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(git:*)"
    ],
    "deny": [
      "Read(./.env*)",
      "Read(./secrets/)",
      "Read(./.ssh/)",
      "Read(./*.key)",
      "Read(./*.pem)"
    ]
  }
}
