#!/bin/bash
# dotfiles — 멀티 머신 dotfiles 제어 CLI (Phase 1)
#
# 제어 머신에서 config/를 편집·커밋하고, 등록된 머신들에 배포한다.
# 배포 = git pull(hub) 또는 git push(direct) + 원격 apply + verify. 자세한 규칙:
#   - 배포되는 것은 항상 커밋이다 (로컬이 dirty면 push를 중단)
#   - 원격이 dirty면 건너뛰고 보고한다 (--force로만 덮어씀)
#
# Usage:
#   dotfiles apply [components]                # 이 머신에 적용 (예: shell,claude,codex)
#   dotfiles push [machine ...] [--all] [--force] [--skip-secret-scan]
#   dotfiles status [machine ...] [--all]      # 머신별 배포 상태/드리프트
#   dotfiles machines                          # 등록된 머신 목록
set -u

# $0가 심링크(~/.local/bin/dotfiles)여도 레포 루트를 올바르게 찾도록 resolve
# (readlink -f는 구형 macOS에 없어 루프로 처리)
SELF="$0"
while [ -L "$SELF" ]; do
  _target="$(readlink "$SELF")"
  case "$_target" in
    /*) SELF="$_target" ;;
    *)  SELF="$(dirname "$SELF")/$_target" ;;
  esac
done
DOTFILES="$(cd "$(dirname "$SELF")/.." && pwd)"
CONFIG="$DOTFILES/config"
SCRIPTS="$DOTFILES/.claude/skills/setup/scripts"
MACHINES_FILE="$CONFIG/machines.toml"
SSH_OPTS="-o BatchMode=yes -o ConnectTimeout=6"

# ---------- machines.toml ----------
# 출력: 한 줄에 name|host|components|transport|path
list_machines() {
  [ -f "$MACHINES_FILE" ] || return 0
  awk '
  function emit() { if (name != "") print name "|" host "|" comps "|" (transport == "" ? "hub" : transport) "|" (path == "" ? "~/dotfiles" : path) }
  /^\[machines\./ {
    emit()
    name = $0; sub(/^\[machines\./, "", name); sub(/\][ \t]*$/, "", name)
    host = ""; comps = ""; transport = ""; path = ""
    next
  }
  /^[ \t]*host[ \t]*=/       { v = $0; sub(/^[^=]*=[ \t]*"/, "", v); sub(/"[ \t]*$/, "", v); host = v }
  /^[ \t]*components[ \t]*=/ { v = $0; sub(/^[^=]*=[ \t]*"/, "", v); sub(/"[ \t]*$/, "", v); comps = v }
  /^[ \t]*transport[ \t]*=/  { v = $0; sub(/^[^=]*=[ \t]*"/, "", v); sub(/"[ \t]*$/, "", v); transport = v }
  /^[ \t]*path[ \t]*=/       { v = $0; sub(/^[^=]*=[ \t]*"/, "", v); sub(/"[ \t]*$/, "", v); path = v }
  END { emit() }
  ' "$MACHINES_FILE"
}

machine_line() {
  list_machines | awk -F'|' -v n="$1" '$1 == n { print; exit }'
}

resolve_targets() {
  # 인자: 머신 이름들 또는 --all → name 목록 출력
  if [ "$1" = "--all" ]; then
    list_machines | cut -d'|' -f1
    return
  fi
  local n
  for n in "$@"; do
    if [ -z "$(machine_line "$n")" ]; then
      echo "[error] unknown machine: $n (dotfiles machines 로 확인)" >&2
      return 1
    fi
    echo "$n"
  done
}

# ---------- secret scan ----------
secret_scan() {
  # config/ 안에 리터럴 secret이 들어갔는지 push 전에 검사한다.
  # 환경변수 참조(os.environ, $VAR)는 매치되지 않도록 따옴표로 감싼 긴 리터럴만 잡는다.
  grep -rEn --exclude-dir=.git --exclude-dir=.stfolder \
    -e '(api[_-]?key|secret|token|passwd|password)[A-Za-z0-9_]*[[:space:]]*[=:][[:space:]]*["'"'"'][A-Za-z0-9_/+.=-]{16,}["'"'"']' \
    -e 'AKIA[0-9A-Z]{16}' \
    -e 'ghp_[A-Za-z0-9]{30,}' \
    -e 'github_pat_[A-Za-z0-9_]{30,}' \
    -e 'xox[baprs]-[A-Za-z0-9-]{10,}' \
    -e 'sk-[A-Za-z0-9_-]{20,}' \
    -e 'BEGIN( RSA| EC| OPENSSH| PGP)? PRIVATE KEY' \
    "$CONFIG" 2>/dev/null
}

# ---------- apply (로컬/원격 공용, 무인 실행) ----------
cmd_apply() {
  local comps="${1:-}"
  if [ -z "$comps" ]; then
    # 미지정 시 config 내용 기반 자동 감지
    comps="shell"
    [ -f "$CONFIG/ai/claude/settings.base.json" ] && comps="$comps,claude"
    [ -f "$CONFIG/ai/codex/config.base.toml" ] && comps="$comps,codex"
    [ -f "$CONFIG/ai/gemini/settings.json" ] && [ -d "$HOME/.gemini" ] && comps="$comps,gemini"
  fi

  # 인스트럭션 모드 감지: 도구별 파일이 있으면 separate, 없으면 unified
  local mode="--unified"
  [ -f "$CONFIG/ai/claude/CLAUDE.md" ] && mode="--separate"

  echo "=== dotfiles apply (components: $comps, mode: ${mode#--}) ==="
  local rc=0 c
  for c in $(echo "$comps" | tr ',' ' '); do
    case "$c" in
      shell)
        # zsh가 설치돼 있으면 로그인 셸과 무관하게 zsh 설정을 적용
        # (서버는 chsh 불가로 로그인 셸이 bash인 경우가 많음 — link-shell이 전환 블록 처리)
        local sh_type
        if command -v zsh >/dev/null 2>&1; then sh_type=zsh; else sh_type="$(basename "${SHELL:-/bin/bash}")"; fi
        bash "$SCRIPTS/link-shell.sh" "$sh_type" || rc=1 ;;
      claude|codex|gemini)
        bash "$SCRIPTS/link-tool.sh" "$c" "$mode" || rc=1 ;;
      *)
        echo "  [warn] unknown component: $c" ;;
    esac
  done

  # 서드파티 스킬 (네트워크 필요 — 실패해도 계속)
  bash "$SCRIPTS/install-manifest-skills.sh" || true

  # CLI를 PATH에 노출
  if [ -d "$HOME/.local/bin" ] || mkdir -p "$HOME/.local/bin"; then
    ln -sfn "$DOTFILES/bin/dotfiles" "$HOME/.local/bin/dotfiles"
  fi

  echo ""
  bash "$SCRIPTS/verify.sh" $mode --tools "$(echo "$comps" | sed 's/shell,\{0,1\}//')" || rc=1

  # apply 성공 시에만 기록 — status가 "pull됐는데 apply 실패"를 감지하는 근거
  if [ $rc -eq 0 ]; then
    local state_dir="$HOME/.local/state/dotfiles"
    mkdir -p "$state_dir" 2>/dev/null
    printf '%s %s %s\n' \
      "$(git -C "$DOTFILES" rev-parse HEAD 2>/dev/null)" \
      "$(git -C "$CONFIG" rev-parse HEAD 2>/dev/null)" \
      "$(date +%s)" > "$state_dir/applied"
  fi

  return $rc
}

# ---------- push ----------
cmd_push() {
  local force=false skip_scan=false
  local names=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --force) force=true ;;
      --skip-secret-scan) skip_scan=true ;;
      --all) names+=("--all") ;;
      -*) echo "[error] unknown flag: $1" >&2; return 1 ;;
      *) names+=("$1") ;;
    esac
    shift
  done
  if [ ${#names[@]} -eq 0 ]; then
    echo "Usage: dotfiles push <machine ...|--all> [--force] [--skip-secret-scan]" >&2
    return 1
  fi
  local targets
  targets="$(resolve_targets "${names[@]}")" || return 1
  [ -n "$targets" ] || { echo "[error] no machines registered in machines.toml" >&2; return 1; }

  # 0) secret 스캔
  if ! $skip_scan; then
    local hits
    hits="$(secret_scan || true)"
    if [ -n "$hits" ]; then
      echo "[abort] config/ 에서 secret 의심 항목 발견 — push 중단:"
      echo "$hits" | head -10 | sed 's/^/  /'
      echo "  (오탐이 확실하면 --skip-secret-scan)"
      return 1
    fi
  fi

  # 1) 로컬은 커밋되어 있어야 한다 (배포 = 커밋 원칙)
  local repo dirty_abort=false
  for repo in "$DOTFILES" "$CONFIG"; do
    if [ -n "$(git -C "$repo" status --porcelain 2>/dev/null)" ]; then
      echo "[abort] uncommitted changes in $repo — 커밋 후 push 하세요"
      dirty_abort=true
    fi
  done
  $dirty_abort && return 1

  # 2) 허브(origin)로 push
  echo "--- pushing to hub ---"
  git -C "$DOTFILES" push origin HEAD || { echo "[error] framework push 실패"; return 1; }
  git -C "$CONFIG" push origin HEAD || { echo "[error] config push 실패"; return 1; }

  # 3) 머신별 배포
  local n line host comps transport path summary=""
  for n in $targets; do
    line="$(machine_line "$n")"
    host="$(echo "$line" | cut -d'|' -f2)"
    comps="$(echo "$line" | cut -d'|' -f3)"
    transport="$(echo "$line" | cut -d'|' -f4)"
    path="$(echo "$line" | cut -d'|' -f5)"
    echo ""
    echo "--- $n ($host, $transport) ---"

    local pull_rc=0
    if [ "$transport" = "direct" ]; then
      # 제어 머신 → 원격으로 직접 push (원격은 receive.denyCurrentBranch=updateInstead 필요)
      git -C "$DOTFILES" push -q "$host:$path" HEAD || pull_rc=1
      git -C "$CONFIG" push -q "$host:$path/config" HEAD || pull_rc=1
      [ $pull_rc -ne 0 ] && echo "  [drift] direct push 거부됨 (원격 dirty 또는 미설정)"
    else
      # hub: 원격이 GitHub에서 pull
      local pull_cmd="git -C $path pull --ff-only && git -C $path/config pull --ff-only"
      if $force; then
        pull_cmd="git -C $path fetch origin && git -C $path reset --hard '@{upstream}' && git -C $path/config fetch origin && git -C $path/config reset --hard '@{upstream}'"
      else
        # dirty 체크 → report-only
        local dirty
        dirty="$(ssh $SSH_OPTS "$host" "git -C $path status --porcelain; git -C $path/config status --porcelain" 2>/dev/null)"
        if [ -n "$dirty" ]; then
          echo "  [drift] 원격에 커밋 안 된 변경 있음 — 건너뜀 (--force로 덮어쓰기 가능)"
          echo "$dirty" | head -5 | sed 's/^/    /'
          summary="$summary\n  $n: DRIFT (skipped)"
          continue
        fi
      fi
      ssh $SSH_OPTS "$host" "$pull_cmd" || pull_rc=1
    fi

    if [ $pull_rc -ne 0 ]; then
      summary="$summary\n  $n: PULL FAILED"
      continue
    fi

    # 원격 apply + verify
    if ssh $SSH_OPTS "$host" "bash $path/bin/dotfiles apply $comps"; then
      summary="$summary\n  $n: OK ($comps)"
    else
      summary="$summary\n  $n: APPLY/VERIFY FAILED"
    fi
  done

  echo ""
  echo "=== push summary ==="
  printf "%b\n" "$summary" | sed '/^$/d'
}

# ---------- status ----------
# 원격에서 단일 ssh 호출로 필요한 모든 정보를 모아온다 (반복 왕복 없음)
_status_remote_script() {
  cat <<'REMOTE_EOF'
path="$1"
case "$path" in
  "~"*) path="$HOME${path#\~}" ;;
esac
if [ ! -d "$path/.git" ]; then
  echo "BOOTSTRAP=no"
  exit 0
fi
echo "BOOTSTRAP=yes"
fw_sha=$(git -C "$path" rev-parse HEAD 2>/dev/null)
cfg_sha=$(git -C "$path/config" rev-parse HEAD 2>/dev/null)
fw_dirty=$(git -C "$path" status --porcelain 2>/dev/null | wc -l | tr -d ' ')
cfg_dirty=$(git -C "$path/config" status --porcelain 2>/dev/null | wc -l | tr -d ' ')
git -C "$path" fetch -q origin 2>/dev/null
git -C "$path/config" fetch -q origin 2>/dev/null
fw_behind=$(git -C "$path" rev-list --count 'HEAD..@{upstream}' 2>/dev/null || echo 0)
cfg_behind=$(git -C "$path/config" rev-list --count 'HEAD..@{upstream}' 2>/dev/null || echo 0)
applied_file="$HOME/.local/state/dotfiles/applied"
applied_fw=""; applied_cfg=""
if [ -f "$applied_file" ]; then
  read -r applied_fw applied_cfg applied_ts < "$applied_file"
fi
echo "FW_SHA=$fw_sha"
echo "CFG_SHA=$cfg_sha"
echo "FW_DIRTY=${fw_dirty:-0}"
echo "CFG_DIRTY=${cfg_dirty:-0}"
echo "FW_BEHIND=${fw_behind:-0}"
echo "CFG_BEHIND=${cfg_behind:-0}"
echo "APPLIED_FW=$applied_fw"
echo "APPLIED_CFG=$applied_cfg"
REMOTE_EOF
}

cmd_status() {
  local names=("$@")
  [ ${#names[@]} -eq 0 ] && names=("--all")
  local targets
  targets="$(resolve_targets "${names[@]}")" || return 1
  [ -n "$targets" ] || { echo "[error] no machines registered in machines.toml" >&2; return 1; }

  STATUS_TMPDIR="$(mktemp -d)"
  trap 'rm -rf "${STATUS_TMPDIR:-}"' EXIT
  local tmpdir="$STATUS_TMPDIR"

  # 로컬(제어 머신) 상태 — dirty 여부 + origin에 push 안 된 커밋 경고
  local control_fw control_cfg
  control_fw="$(git -C "$DOTFILES" rev-parse HEAD 2>/dev/null)"
  control_cfg="$(git -C "$CONFIG" rev-parse HEAD 2>/dev/null)"
  local control_dirty=""
  [ -n "$(git -C "$DOTFILES" status --porcelain 2>/dev/null)" ] && control_dirty=" [dirty]"
  [ -n "$(git -C "$CONFIG" status --porcelain 2>/dev/null)" ] && control_dirty=" [dirty]"
  echo "control: fw=${control_fw:0:7} cfg=${control_cfg:0:7}${control_dirty}"

  local fw_ahead cfg_ahead
  fw_ahead="$(git -C "$DOTFILES" rev-list --count '@{upstream}..HEAD' 2>/dev/null || echo 0)"
  cfg_ahead="$(git -C "$CONFIG" rev-list --count '@{upstream}..HEAD' 2>/dev/null || echo 0)"
  [ "${fw_ahead:-0}" -gt 0 ] 2>/dev/null && echo "  ⚠ dotfiles: origin에 push 안 된 커밋 ${fw_ahead}개"
  [ "${cfg_ahead:-0}" -gt 0 ] 2>/dev/null && echo "  ⚠ config: origin에 push 안 된 커밋 ${cfg_ahead}개"
  echo ""

  local n line host path
  for n in $targets; do
    line="$(machine_line "$n")"
    host="$(echo "$line" | cut -d'|' -f2)"
    path="$(echo "$line" | cut -d'|' -f5)"
    (
      ssh $SSH_OPTS "$host" bash -s -- "$path" > "$tmpdir/$n.out" 2>"$tmpdir/$n.err" < <(_status_remote_script)
      echo "$?" > "$tmpdir/$n.rc"
    ) &
  done
  wait

  # MACHINE 컬럼 너비 (최소 "MACHINE" 길이)
  local name_w=7
  for n in $targets; do
    [ ${#n} -gt $name_w ] && name_w=${#n}
  done

  printf "%-${name_w}s  %-24s  %s\n" "MACHINE" "STATE" "APPLIED"
  for n in $targets; do
    local rc out err state applied
    rc="$(cat "$tmpdir/$n.rc" 2>/dev/null || echo 255)"
    out="$(cat "$tmpdir/$n.out" 2>/dev/null)"
    err="$(cat "$tmpdir/$n.err" 2>/dev/null)"

    if [ "$rc" != "0" ] || [ -z "$out" ]; then
      local reason="unknown"
      if echo "$err" | grep -qi 'permission denied'; then reason="auth"
      elif echo "$err" | grep -qiE 'timed out'; then reason="timeout"
      elif echo "$err" | grep -qi 'could not resolve hostname'; then reason="dns"
      elif echo "$err" | grep -qi 'connection refused'; then reason="refused"
      fi
      state="✗ unreachable (${reason})"
      applied="-"
    else
      local bootstrap
      bootstrap="$(echo "$out" | awk -F= '$1=="BOOTSTRAP"{print $2}')"
      if [ "$bootstrap" = "no" ]; then
        state="○ not bootstrapped"
        applied="-"
      else
        local fw_sha cfg_sha fw_dirty cfg_dirty fw_behind cfg_behind applied_fw applied_cfg
        fw_sha="$(echo "$out" | awk -F= '$1=="FW_SHA"{print $2}')"
        cfg_sha="$(echo "$out" | awk -F= '$1=="CFG_SHA"{print $2}')"
        fw_dirty="$(echo "$out" | awk -F= '$1=="FW_DIRTY"{print $2}')"
        cfg_dirty="$(echo "$out" | awk -F= '$1=="CFG_DIRTY"{print $2}')"
        fw_behind="$(echo "$out" | awk -F= '$1=="FW_BEHIND"{print $2}')"
        cfg_behind="$(echo "$out" | awk -F= '$1=="CFG_BEHIND"{print $2}')"
        applied_fw="$(echo "$out" | awk -F= '$1=="APPLIED_FW"{print $2}')"
        applied_cfg="$(echo "$out" | awk -F= '$1=="APPLIED_CFG"{print $2}')"

        local dirty_total=$(( ${fw_dirty:-0} + ${cfg_dirty:-0} ))
        local behind_total=$(( ${fw_behind:-0} + ${cfg_behind:-0} ))

        if [ "$dirty_total" -gt 0 ]; then
          state="⚠ drift"
        elif [ "$behind_total" -gt 0 ]; then
          state="↓ behind ${behind_total}"
        else
          state="✓ synced"
        fi

        if [ -z "$applied_fw" ]; then
          applied="? never"
        elif [ "$applied_fw" = "$fw_sha" ] && [ "$applied_cfg" = "$cfg_sha" ]; then
          applied="✓ ok"
        else
          applied="⚠ stale"
        fi
      fi
    fi

    printf "%-${name_w}s  %-24s  %s\n" "$n" "$state" "$applied"
  done
}

# ---------- main ----------
case "${1:-}" in
  apply)    shift; cmd_apply "$@" ;;
  push)     shift; cmd_push "$@" ;;
  status)   shift; cmd_status "$@" ;;
  machines) list_machines | awk -F'|' '{ printf "%-16s host=%-28s components=%-24s transport=%-7s path=%s\n", $1, $2, $3, $4, $5 }' ;;
  *)
    sed -n '2,15p' "$0" | sed 's/^# \{0,1\}//'
    exit 1
    ;;
esac
